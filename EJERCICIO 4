//PROCESO PARA CALCULAR SUMA, RESTA, MULTIPLICACION Y DIVISION DE LOS DOS NUMEROS
PROCESO SUMA,RESTA,MULTIPLICACIONYDIVISION
 ESCRIBIR "BIENVENIDO AL PROGRAMA QUE TE VA A SUMAR, RESTAR, MULTIPLICAR Y DIVIDIR DOS NUMEROS"
 ESCRIBIR "DIGITE NUM1"
 LEER NUM1
 ESCRIBIR "DIGITE NUM2"
 LEER NUM2
 RESPUESTASUMA = NUM1 + NUM2
 RESPUESTARESTA = NUM1 - NUM2
 RESPUESTAMULTIPLICACION = NUM1 * NUM2
 RESPUESTADIVISION = NUM1 / NUM2
 ESCRIBIR "SI EL PRIMER NUMERO ES ", NUM1, " Y EL SEGUNDO ", NUM2, ", ENTONCES EL RESULTADO DE LA SUMA ES ", RESPUESTASUMA, ", EL DE LA RESTA ES ", RESPUESTARESTA, ", EL DE LA MULTIPLICACION ES ", RESPUESTAMULTIPLICACION, " Y EL DE LA DIVISION ES ", RESPUESTADIVISION
FINPROCESO
