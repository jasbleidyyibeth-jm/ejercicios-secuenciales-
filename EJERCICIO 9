// PROCESO PARA SACAR EL 15% DE DESCUENTO EN LA COMPRA QUE HAGAS 
PROCESO PARASACAREL15%DEDESCUENTOENUNACOMPRA
 ESCRIBIR "BIENVENIDO, ESTE PROGRAMA TE AYUDARA A SACAR EL 15% DE DESCUENTO EN TU COMPRA"
 ESCRIBIR "DIGITE EL VALOR TOTAL"
 LEER VALORTOTAL
 RESULTADO = VALORTOTAL * 15 / 100
 ESCRIBIR "SI EL VALOR DE TU COMPRA ES DE ", VALORTOTAL, ", ENTONCES SI LE APLICAMOS EL DESCUENTO DEL 15% TE TOCARA PAGAR ", RESULTADO
FINPROCESO
