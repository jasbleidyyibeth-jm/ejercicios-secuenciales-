//PROCESO PARA CALCULAR LA HIPOTENUSA DE UN TRIANGULO RECTANGULO DADO LOS CATETOS
PROCESO BIENVENIDA
 ESCRIBIR "ESTE PROGRAMA TE VA A AYUDAR A CALCULAR LA HIPOTENUSA DE UN TRIANGULO RECTANGULO DADO SUS CATETOS"
 ESCRIBIR "INGRESE EL VALOR DEL CATETO1"
 LEER CATETO1
 ESCRIBIR "INGRESE EL VALOR DEL CATETO2"
 LEER CATETO2
 RESULTADO = RAIZ ((CATETO1 * CATETO1) + (CATETO2 * CATETO2))
 ESCRIBIR "SI EL CATETO1 MIDE ", CATETO1, " Y EL CATETO2 ", CATETO2, ", ENTOCES LA HIPOTENUSA MIDE ", RESULTADO
FINPROCESO
