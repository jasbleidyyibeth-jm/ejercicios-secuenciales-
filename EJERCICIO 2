//PROGRAMA QUE CALCULA EL AREA Y PERIMETRO DE UN RECTANGULO
PROCESO AREAYPERIMETRODEUNRECTANGULO
 ESCRIBIR "PROGRAMA QUE CALCULA EL AREA Y PERIMETRO DE UNA CIRCUNFERENCIA"
 ESCRIBIR "DIGITE LA BASE DEL RECTANGULO"
 LEER BASE
 ESCRIBIR "DIGITE ALTURA"
 LEER ALTURA
 AREA = BASE * ALTURA
 PERIMETRO = 2 * (BASE + ALTURA)
 ESCRIBIR "SI LA BASE DEL RECTANGULO ES ", BASE, ", LA ALTURA ", ALTURA, ", ENTONCES EL AREA DEL RECTANGULO ES ", AREA, " Y EL PERIMETRO ES ", PERIMETRO
 FINPROCESO
