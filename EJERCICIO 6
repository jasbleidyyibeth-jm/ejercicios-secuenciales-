// PROCESO DE COM0 SACAR LA MEDIA DE 3 NUMEROS
Proceso MEDIADE3NUMEROS
 ESCRIBIR "HOLA, BIENVENIDO AL PROGRAMA QUE TE VA A SACAR LA MEDIA DE 3 NUMEROS"
 ESCRIBIR "DIGITE EL NUM1"
 LEER NUM1
 ESCRIBIR "DIGITE EL NUM2"
 LEER NUM2
 ESCRIBIR "DIGITE EL NUM3"
 LEER NUM3
 RESULTADO = (NUM1 + NUM2 + NUM3) / 3
 ESCRIBIR "SI EL NUM1 ES ", NUM1, ", EL NUM2 ", NUM2, " Y EL NUM3 ", NUM3, ", ENTONCES LA MEDIA DE LOS 3 NUMEROS TE VA A DAR ", RESULTADO
FinProceso
