//PROGRAMA QUE PASA DE MINUTOS A HORAS Y MINUTOS
Proceso PASADEHORASAMINUTOSYSEGUNDOS
	DEFINIR HORAS COMO ENTEROS // ESTOY DECLARANDO UNA VARIABLE COMO ENTERA
	ESCRIBIR "BIENVENIDO AL PROGRMA QUE PASA CIERTA CANTIDAD DE MINUTOS A HORAS Y MINUTOS"
	ESCRIBIR "DIGITE LA CANTIDAD DE MINUTOS"
	LEER MINUTOS
	HORAS = TRUNC (MINUTOS / 60)
	RES = MINUTOS / 60 - HORAS
	MINU = RES * 60
	ESCRIBIR "HORAS : ", HORAS
	ESCRIBIR "MINUTOS: ", MINU
FinProceso
