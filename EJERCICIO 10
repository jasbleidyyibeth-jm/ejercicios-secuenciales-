// PROCESO PARA SABER CUAL SERA TU NOTA FINAL
PROCESO PARASACARELPORCENTAJEFINAL
 ESCRIBIR "BIENVENIDO, TE AYUDARE A SACAR EL PROMEDIO DE LA NOTA FINAL"
 ESCRIBIR "INGRESE NOTA1"
 LEER NOTA1
 ESCRIBIR "INGRESE NOTA2"
 LEER NOTA2
 ESCRIBIR "INGRESE NOTA3"
 LEER NOTA3
 PROMEDIOPARCIALES = (NOTA1 + NOTA2 + NOTA3) / 3
 ESCRIBIR "INGRESE NOTA DEL EXAMEN FINAL"
 LEER EXAMENFINAL
 ESCRIBIR "INGRESE NOTA DEL TRABAJO FINAL"
 LEER TRABAJOFINAL
 RESULTADO = (PROMEDIOPARCIALES * 55 / 100) + (EXAMENFINAL * 30 / 100) + (TRABAJOFINAL * 15 / 100)
 ESCRIBIR "LA CALIFICACION FINAL ES DE ", RESULTADO
FINPROCESO
